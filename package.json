{
  "name": "@theclawlab/cmds",
  "type": "module",
  "version": "1.0.8",
  "description": "cmds is a linux command for discovery of all other linux commands in current OS, for human and AI.",
  "bin": {
    "cmds": "dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "release:local": "npm run build && npm link",
    "release:public": "npm test && npm run build && npm publish --access public",
    "release:public:skip-test": "npm run build && npm publish --access public",
    "prepare:reload": "npx tsx scripts/reload.ts",
    "prepare:categorize": "npx tsx scripts/categorize.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "README.md",
    "USAGE.md"
  ],
  "devDependencies": {
    "@types/node": "^25.4.0",
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fuzzysort": "^3.1.0"
  }
}
